# ================================================================================================
# 🎯 PROJECT CONFIGURATION (90-project.env)
# ================================================================================================
#
# Purpose: Project-specific overrides and custom configuration for go-lucky
# Load Order: 90 (loaded after all defaults, overrides tool-specific settings)
#
# This file contains project-specific configuration including:
# - Coverage provider and exclusion overrides
# - Google Analytics configuration
# - Any custom settings unique to this project
#
# Override in: 99-local.env (local development only, git-ignored)
#
# ================================================================================================

# ================================================================================================
# 🎯 GO VERSION CONFIGURATION
# ================================================================================================

# Project Go versions (overrides 00-core.env defaults)
GO_PRIMARY_VERSION=1.25.x
GO_SECONDARY_VERSION=1.25.x

# ================================================================================================
# 🪄 MAGE-X GO VERSION OVERRIDES
# ================================================================================================

MAGE_X_GO_VERSION=1.25.x
MAGE_X_GO_SECONDARY_VERSION=1.25.x

# ================================================================================================
# 📊 COVERAGE CONFIGURATION OVERRIDES
# ================================================================================================

# Coverage Report Provider (codecov for this project)
GO_COVERAGE_PROVIDER=codecov

# Codecov Configuration
CODECOV_TOKEN_REQUIRED=true

# Coverage Exclusions (aligned with codecov.yml ignore paths)
GO_COVERAGE_EXCLUDE_PATHS=.github/,.mage-cache/,.vscode/,bin/,example/,examples/,mocks/,testing/

# ================================================================================================
# 📈 GOOGLE ANALYTICS CONFIGURATION
# ================================================================================================

# Google Analytics ID (for coverage pages)
GOOGLE_ANALYTICS_ID=G-LP3T2BTXMG
